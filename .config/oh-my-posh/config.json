{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": ""
        },
        {
          "foreground": "#757575",
          "style": "plain",
          "template": "\u250c {{ .UserName }} ",
          "type": "session"
        },
        {
          "background": "#7c6f64",
          "foreground": "#100e23",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#757575",
          "style": "plain",
          "template": "\n\u2514 ",
          "type": "text"
        },
        {
          "foreground": "#ffffff",
          "style": "plain",
          "template": "$",
          "type": "text"
        }
      ]
    }
  ],
  "version": 4
}
